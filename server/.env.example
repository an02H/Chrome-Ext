# ── LLM Capture Pro — Configuration ──────────────────────────────────────────

# 1. Clé API Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-VOTRE_CLE_ICI

# 2. Google OAuth2 — créer un projet sur https://console.cloud.google.com
#    Activer "Google Drive API", créer des identifiants OAuth2 "Application de bureau"
GOOGLE_CLIENT_ID=VOTRE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=VOTRE_CLIENT_SECRET

# 3. Refresh token — obtenu via: GET http://localhost:3747/auth/google
#    puis POST http://localhost:3747/auth/google/callback avec le code reçu
GOOGLE_REFRESH_TOKEN=

# 4. (Optionnel) ID du dossier Google Drive cible
#    Laisser vide = racine "Mon Drive"
#    Trouver l'ID dans l'URL Drive: https://drive.google.com/drive/folders/CECI_EST_L_ID
GOOGLE_DRIVE_FOLDER_ID=
